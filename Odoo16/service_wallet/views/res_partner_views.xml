<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- View res.partner form -->
    <record id="view_res_partner_form" model="ir.ui.view">
        <field name="name">view.res.partner.form</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='vat']" position="after">
                <field name="remaining_hours" groups="service_wallet.service_wallet_transaction_user" widget="float_time"/>
            </xpath>
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_wallet_transactions" type="object" groups="service_wallet.service_wallet_transaction_user" class="oe_stat_button" icon="fa-list-alt">
                    <field name="transaction_count" widget="statinfo" string="Wallet Transactions"/>
                </button>
            </xpath>
        </field>
    </record>

</odoo>