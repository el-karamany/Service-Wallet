<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- View service.wallet.transaction View List -->
    <record id="view_service_wallet_transaction_tree" model="ir.ui.view">
        <field name="name">view.service.wallet.transaction.tree</field>
        <field name="model">service.wallet.transaction</field>
        <field name="arch" type="xml">
            <list create="0" edit="0" delete="0">
                <field name="partner_id"/>
                <field name="amount" widget="float_time"/>
                <field name="description"/>
                <field name="date"/>
                <field name="source"/>
                <field name="related_sales_order" />
                <field name="transaction_type"/>
            </list>
        </field>
    </record>

    <!-- View service.wallet.transaction search -->
    <record id="view_service_wallet_transaction_search" model="ir.ui.view">
        <field name="name">view.service.wallet.transaction.search</field>
        <field name="model">service.wallet.transaction</field>
        <field name="arch" type="xml">
            <search>
                <group expand="1" string="Group By">
                    <filter string="Partner" name="partner_id" domain="[]" context="{'group_by':'partner_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action service.wallet.transaction -->
    <record id="action_service_wallet_transaction" model="ir.actions.act_window">
        <field name="name">Service Wallet Transaction</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">service.wallet.transaction</field>
        <field name="view_mode">list</field>
        <field name="domain">[]</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                There is no Service Wallet Transactions.
            </p>
        </field>
    </record>

    <!-- Change sequnce of configuration in contacts to be the last which is sequnce of 3-->
    <record id="contacts.res_partner_menu_config" model="ir.ui.menu">
        <field name="sequence" eval="3"/>
    </record>

    <menuitem
        id="wallet_transactions_menu"
        name="Wallet Transactions"
        parent="contacts.menu_contacts"
        sequence="2"/>

    <menuitem
        id="transactions_history_menu"
        name="Transactions History"
        parent="wallet_transactions_menu"
        action="action_service_wallet_transaction"
        sequence="1"/>

</odoo>
