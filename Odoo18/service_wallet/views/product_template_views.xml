<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <!-- View product.template form -->
    <record id="view_product_template_form" model="ir.ui.view">
        <field name="name">view.product.template.form</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_policy']" position="after">
                <field name="is_prepaid_pack" groups="service_wallet.service_wallet_transaction_user"/>
                <field name="pack_hours" groups="service_wallet.service_wallet_transaction_user" widget="float_time"/>
            </xpath>
        </field>
    </record>

</odoo>